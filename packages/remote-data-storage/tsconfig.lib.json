{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "dist",
        "types": ["node", "vite/client"],
        "rootDir": "src",
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo"
    },
    "include": ["src/**/*.ts"],
    "references": [
        {
            "path": "../core/tsconfig.lib.json"
        },
        {
            "path": "../utils/tsconfig.lib.json"
        }
    ]
}
